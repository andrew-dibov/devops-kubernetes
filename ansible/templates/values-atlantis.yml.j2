atlantisUrl: "{{ helm_atlantis_url }}"
orgAllowlist: "{{ helm_atlantis_allowlist }}"

githubApp:
  id: "{{ github_app_id }}"
  secret: "{{ github_app_secret }}"
  key: |
    {{ github_app_key | indent(4) }}

volumeClaim:
  enabled: false

affinity:
  nodeAffinity:
    requiredDuringSchedulingIgnoredDuringExecution:
      nodeSelectorTerms:
      - matchExpressions:
        - key: kubernetes.io/hostname
          operator: In
          values:
          - {{ atlantis_node }}

containerSecurityContext:
  readOnlyRootFilesystem: false

statefulSet:
  securityContext:
    fsGroup: 100
    runAsUser: 100
    runAsGroup: 100

extraVolumes:
  - name: atlantis-volume
    persistentVolumeClaim:
      claimName: "{{ helm_atlantis_persistent_volume_claim_name }}"

  - name: atlantis-terraformrc-volume
    configMap:
      name: atlantis-terraformrc

  - name: atlantis-yc-key-volume
    secret:
      secretName: atlantis-yc-key

extraVolumeMounts:
  - name: atlantis-volume
    mountPath: /atlantis-data

  - name: atlantis-terraformrc-volume
    mountPath: /home/atlantis/.terraformrc
    subPath: terraformrc
    readOnly: true

  - name: atlantis-yc-key-volume
    mountPath: /home/atlantis/.yandex
    readOnly: true

environment:
  YC_SERVICE_ACCOUNT_KEY_FILE: "/home/atlantis/.yandex/terraform.key.json"
  TF_VAR_bucket: "{{ terraform_backend }}"
  TF_CLI_ARGS_init: "-backend-config=bucket={{ terraform_backend }}"
  AWS_ACCESS_KEY_ID: "{{ aws_access_key_id }}"
  AWS_SECRET_ACCESS_KEY: "{{ aws_secret_access_key }}"
