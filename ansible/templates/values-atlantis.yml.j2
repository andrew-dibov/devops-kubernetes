atlantisUrl: "{{ atlantis_url }}"
orgAllowlist: "{{ atlantis_allowlist }}"

githubApp:
  id: "{{ github_app_id }}"
  secret: "{{ github_app_secret }}"
  key: |
    {{ github_app_key | indent(4) }}

volumeClaim:
  enabled: false

affinity:
  nodeAffinity:
    requiredDuringSchedulingIgnoredDuringExecution:
      nodeSelectorTerms:
      - matchExpressions:
        - key: kubernetes.io/hostname
          operator: In
          values:
          - {{ atlantis_node }}

containerSecurityContext:
  readOnlyRootFilesystem: false

statefulSet:
  securityContext:
    fsGroup: 100
    runAsUser: 100
    runAsGroup: 100

extraVolumes:
  - name: atlantis-volume
    persistentVolumeClaim:
      claimName: "{{ atlantis_pvc }}"

  - name: terraformrc-volume
    configMap:
      name: atlantis-terraformrc

  - name: terraform-key-volume
    secret:
      secretName: yc-sa-key

  - name: terraform-files-volume
    configMap:
      name: atlantis-terraform-files

extraVolumeMounts:
  - name: atlantis-volume
    mountPath: /atlantis-data

  - name: terraformrc-volume
    mountPath: /home/atlantis/.terraformrc
    subPath: terraformrc
    readOnly: true

  - name: terraform-key-volume
    mountPath: /home/atlantis/.yandex
    readOnly: true

environment:
  YC_SERVICE_ACCOUNT_KEY_FILE: "/home/atlantis/.yandex/terraform.key.json"
  TF_VAR_bucket: "{{ terraform_backend }}"

extraArgs:
  - --tf-init-extra-args=-backend-config=bucket=${TF_VAR_bucket}
