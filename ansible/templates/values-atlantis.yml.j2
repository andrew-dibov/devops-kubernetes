atlantisUrl: "{{ atlantis_url }}"
orgAllowlist: "{{ atlantis_allowlist }}"

githubApp:
  id: "{{ github_app_id }}"
  secret: "{{ github_app_secret }}"
  key: |
    {{ github_app_key | indent(4) }}

volumeClaim:
  enabled: false

affinity:
  nodeAffinity:
    requiredDuringSchedulingIgnoredDuringExecution:
      nodeSelectorTerms:
      - matchExpressions:
        - key: kubernetes.io/hostname
          operator: In
          values:
          - {{ atlantis_node }}

containerSecurityContext:
  readOnlyRootFilesystem: false

statefulSet:
  securityContext:
    fsGroup: 100
    runAsUser: 100
    runAsGroup: 100

extraVolumes:
  - name: atlantis-volume
    persistentVolumeClaim:
      claimName: "{{ atlantis_pvc }}"

  - name: terraformrc-volume
    configMap:
      name: atlantis-terraformrc

  - name: terraform-key-volume
    secret:
      secretName: yc-sa-key

  - name: terraform-files-volume
    configMap:
      name: atlantis-terraform-files

extraVolumeMounts:
  - name: atlantis-volume
    mountPath: /atlantis-data

  - name: terraformrc-volume
    mountPath: /home/atlantis/.terraformrc
    subPath: terraformrc
    readOnly: true

  - name: terraform-key-volume
    mountPath: /home/atlantis/.yandex
    readOnly: true

  - name: terraform-files-volume
    mountPath: /tmp/atlantis-tf-files
    readOnly: true

environment:
  YC_SERVICE_ACCOUNT_KEY_FILE: "/home/atlantis/.yandex/terraform.key.json"
  S3_BUCKET_NAME: "{{ terraform_backend }}"

extraArgs:
  - --tf-init-extra-args=-backend-config=bucket=${S3_BUCKET_NAME} -backend-config="key=kubernetes/terraform.tfstate" -backend-config="region=ru-central1" -backend-config="endpoints={s3=\"https://storage.yandexcloud.net\"}" -backend-config="skip_credentials_validation=true" -backend-config="skip_region_validation=true" -backend-config="use_path_style=true"
  - --tf-plan-extra-args=-var="s3_bucket_name=${S3_BUCKET_NAME}"
  - --tf-apply-extra-args=-var="s3_bucket_name=${S3_BUCKET_NAME}"
